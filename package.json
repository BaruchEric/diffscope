{
  "name": "diffscope",
  "version": "0.0.1",
  "description": "A local, read-only, live git diff viewer.",
  "type": "module",
  "bin": {
    "diffscope": "./bin/diffscope.ts"
  },
  "scripts": {
    "dev": "(trap 'kill 0' INT; DIFFSCOPE_DEV_PORT=41111 bun run dev:server & bun run dev:web & wait)",
    "dev:server": "bun run --hot src/server/cli.ts",
    "dev:web": "vite",
    "build:web": "vite build",
    "start": "bun run src/server/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.web.json",
    "lint": "oxlint",
    "postinstall": "bash scripts/postinstall-node-pty.sh"
  },
  "dependencies": {
    "@parcel/watcher": "^2.4.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shiki": "^4.0.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "oxlint": "^1.59.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4",
    "typescript": "^5.6.0",
    "vite": "^8.0.8"
  }
}
